{
  "name": "shadowrecon-ultimate",
  "productName": "ShadowRecon Ultimate",
  "version": "1.0.0",
  "description": "Advanced desktop dashboard built with Electron",
  "main": "main.js",
  "author": {
    "name": "ShadowRecon Labs",
    "email": "shadowrecon@local"
  },
  "license": "MIT",
  "private": true,

  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win portable",
    "pack": "electron-builder --dir",
    "clean": "rimraf dist node_modules"
  },

  "dependencies": {
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "axios": "^1.7.9",
    "extract-zip": "^2.0.1",
    "node-notifier": "^10.0.1",
    "screenshot-desktop": "^1.15.0",
    "tesseract.js": "^5.1.0"
  },

  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "rimraf": "^5.0.7"
  },

  "build": {
    "appId": "com.shadowrecon.ultimate",
    "productName": "ShadowRecon Ultimate",

    "directories": {
      "output": "dist"
    },

    "files": [
      "**/*",
      "!dist/**/*",
      "!node_modules/.cache/**/*"
    ],

    "asar": true,

    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
